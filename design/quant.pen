                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "mxptN",
                  "name": "u12",
                  "fill": "#FAFAFA",
                  "content": "All tests pass. The mutex ensures only one goroutine refreshes the token at a time.",
