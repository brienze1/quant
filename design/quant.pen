                  "name": "t3",
                  "fill": "#4B5563",
                  "content": "│ /campaign-manager-api (fix/auth-flow)             │",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "LD1zT",
                  "name": "t4",
                  "fill": "#2a2a2a",
                  "content": "╰──────────────────────────────────────────────────╯",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "oGH0q",
                  "name": "t5",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "RG5wQ",
                  "name": "t6",
                  "fill": "#FAFAFA",
                  "content": "> fix the jwt token refresh race condition in auth middleware",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ZFFjs",
                  "name": "t7",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OkSp7",
                  "name": "t8",
                  "fill": "#FAFAFA",
                  "content": "I'll investigate the auth middleware to find and fix the race condition.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "zSU1u",
                  "name": "t9",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "8uYa9",
                  "name": "t10",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Ni5vH",
                  "name": "t11",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "5BkZt",
                  "name": "t12",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "DTdyh",
                  "name": "t13",
                  "fill": "#FAFAFA",
                  "content": "Found the issue. Multiple goroutines can trigger concurrent token refreshes.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "AiyLt",
                  "name": "t14",
                  "fill": "#FAFAFA",
                  "content": "Adding a sync.Mutex to serialize refresh operations.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "YgNKf",
                  "name": "u1",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lSBUB",
                  "name": "u2",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "I6RI8",
                  "name": "u3",
                  "fill": "#10B981",
                  "content": "   + var refreshMu sync.Mutex",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "BXh05",
                  "name": "u4",
                  "fill": "#10B981",
                  "content": "   + refreshMu.Lock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "z9yj4",
                  "name": "u5",
                  "fill": "#10B981",
                  "content": "   + defer refreshMu.Unlock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "NQ8NK",
                  "name": "u6",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "LxwRH",
                  "name": "u7",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "9V9t5",
                  "name": "u8",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "xQhFG",
                  "name": "u9",
                  "fill": "#F59E0B",
                  "content": "  Bash go test ./internal/auth/...",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Va93b",
                  "name": "u10",
                  "fill": "#10B981",
                  "content": "  ok   campaign-manager-api/internal/auth  0.043s",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OaXCR",
                  "name": "u11",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
