                  "fill": "#FAFAFA",
                  "content": "> fix the jwt token refresh race condition in auth middleware",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "HJAgJ",
                  "name": "t7",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "XlBqS",
                  "name": "t8",
                  "fill": "#FAFAFA",
                  "content": "I'll investigate the auth middleware to find and fix the race condition.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "LQmln",
                  "name": "t9",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "6pH0P",
                  "name": "t10",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Ayj3J",
                  "name": "t11",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "wmqxB",
                  "name": "t12",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "RS8Cq",
                  "name": "t13",
                  "fill": "#FAFAFA",
                  "content": "Found the issue. Multiple goroutines can trigger concurrent token refreshes.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "njVV5",
                  "name": "t14",
                  "fill": "#FAFAFA",
                  "content": "Adding a sync.Mutex to serialize refresh operations.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Hm9KZ",
                  "name": "u1",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Yiibo",
                  "name": "u2",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "zjrMd",
                  "name": "u3",
                  "fill": "#10B981",
                  "content": "   + var refreshMu sync.Mutex",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "y3maB",
                  "name": "u4",
                  "fill": "#10B981",
                  "content": "   + refreshMu.Lock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "dCFcD",
                  "name": "u5",
                  "fill": "#10B981",
                  "content": "   + defer refreshMu.Unlock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "gvruW",
                  "name": "u6",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "CgFuO",
                  "name": "u7",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "3ECI5",
                  "name": "u8",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
