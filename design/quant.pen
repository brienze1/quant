                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "wFjtH",
                  "name": "t10",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "dD8Qw",
                  "name": "t11",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
