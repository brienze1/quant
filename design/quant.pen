                  "name": "t3",
                  "fill": "#4B5563",
                  "content": "│ /campaign-manager-api (fix/auth-flow)             │",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "1NSKc",
                  "name": "t4",
                  "fill": "#2a2a2a",
                  "content": "╰──────────────────────────────────────────────────╯",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "rZECm",
                  "name": "t5",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "1vc9f",
                  "name": "t6",
                  "fill": "#FAFAFA",
                  "content": "> fix the jwt token refresh race condition in auth middleware",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "S0QWq",
                  "name": "t7",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "IbkBd",
                  "name": "t8",
                  "fill": "#FAFAFA",
                  "content": "I'll investigate the auth middleware to find and fix the race condition.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "PrEL0",
                  "name": "t9",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "6LHJF",
                  "name": "t10",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "O5jbw",
                  "name": "t11",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "bjwFR",
                  "name": "t12",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "SvZ3O",
                  "name": "t13",
                  "fill": "#FAFAFA",
                  "content": "Found the issue. Multiple goroutines can trigger concurrent token refreshes.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "duV2V",
                  "name": "t14",
                  "fill": "#FAFAFA",
                  "content": "Adding a sync.Mutex to serialize refresh operations.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "AF63U",
                  "name": "u1",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "PTHKn",
                  "name": "u2",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "MXlQR",
                  "name": "u3",
                  "fill": "#10B981",
                  "content": "   + var refreshMu sync.Mutex",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "MkBFp",
                  "name": "u4",
                  "fill": "#10B981",
                  "content": "   + refreshMu.Lock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "AS4Gs",
                  "name": "u5",
                  "fill": "#10B981",
                  "content": "   + defer refreshMu.Unlock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lkRqA",
                  "name": "u6",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ZIBHr",
                  "name": "u7",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ewuuU",
                  "name": "u8",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "6dT7Q",
                  "name": "u9",
                  "fill": "#F59E0B",
                  "content": "  Bash go test ./internal/auth/...",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "r5DFp",
                  "name": "u10",
                  "fill": "#10B981",
                  "content": "  ok   campaign-manager-api/internal/auth  0.043s",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Pu9Rv",
                  "name": "u11",
