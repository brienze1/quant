                },
                {
                  "type": "text",
                  "id": "EEUUA",
                  "name": "t6",
                  "fill": "#FAFAFA",
                  "content": "> fix the jwt token refresh race condition in auth middleware",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "KD8wC",
                  "name": "t7",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "cFa5i",
                  "name": "t8",
                  "fill": "#FAFAFA",
                  "content": "I'll investigate the auth middleware to find and fix the race condition.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lA2Wr",
                  "name": "t9",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "wFjtH",
                  "name": "t10",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "dD8Qw",
                  "name": "t11",
                  "fill": "#6B7280",
                  "content": "  Read internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "oZ086",
                  "name": "t12",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "RfPdA",
                  "name": "t13",
                  "fill": "#FAFAFA",
                  "content": "Found the issue. Multiple goroutines can trigger concurrent token refreshes.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "sd9b2",
                  "name": "t14",
                  "fill": "#FAFAFA",
                  "content": "Adding a sync.Mutex to serialize refresh operations.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "BmzxO",
                  "name": "u1",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ZOKHI",
                  "name": "u2",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ihQft",
                  "name": "u3",
                  "fill": "#10B981",
                  "content": "   + var refreshMu sync.Mutex",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "WNzRk",
                  "name": "u4",
                  "fill": "#10B981",
                  "content": "   + refreshMu.Lock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "022p9",
                  "name": "u5",
                  "fill": "#10B981",
                  "content": "   + defer refreshMu.Unlock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "su89j",
                  "name": "u6",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "LBteT",
                  "name": "u7",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/token_refresh.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "GgxJJ",
                  "name": "u8",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7YRA8",
                  "name": "u9",
                  "fill": "#F59E0B",
                  "content": "  Bash go test ./internal/auth/...",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "CvdOr",
                  "name": "u10",
                  "fill": "#10B981",
                  "content": "  ok   campaign-manager-api/internal/auth  0.043s",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "B6sHq",
                  "name": "u11",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7s5g4",
                  "name": "u12",
                  "fill": "#FAFAFA",
                  "content": "All tests pass. The mutex ensures only one goroutine refreshes the token at a time.",
