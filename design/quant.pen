                      "name": "sc1",
                      "fill": "#6B7280",
                      "content": "#!/bin/bash",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "UODUz",
                      "name": "sc2",
                      "fill": "#6B7280",
                      "content": "set -euo pipefail",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "1n5tK",
                      "name": "sc3",
                      "fill": "#FAFAFA",
                      "content": " ",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "35Oyo",
                      "name": "sc4",
                      "fill": "#FAFAFA",
                      "content": "echo \"Verifying backup...\"",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "hpXW4",
                      "name": "sc5",
                      "fill": "#FAFAFA",
                      "content": "pg_verify_checksums -D $PGDATA",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "MgtbX",
                      "name": "sc6",
                      "fill": "#FAFAFA",
                      "content": " ",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "U6XQB",
                      "name": "sc7",
                      "fill": "#F59E0B",
                      "content": "if [ $? -eq 0 ]; then",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "0QDOk",
                      "name": "sc8",
                      "fill": "#FAFAFA",
