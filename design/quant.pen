                },
                {
                  "type": "text",
                  "id": "ZOKHI",
                  "name": "u2",
                  "fill": "#10B981",
                  "content": "  Edit internal/auth/middleware.go",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ihQft",
                  "name": "u3",
                  "fill": "#10B981",
                  "content": "   + var refreshMu sync.Mutex",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "WNzRk",
                  "name": "u4",
                  "fill": "#10B981",
                  "content": "   + refreshMu.Lock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "022p9",
                  "name": "u5",
                  "fill": "#10B981",
                  "content": "   + defer refreshMu.Unlock()",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "su89j",
                  "name": "u6",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
