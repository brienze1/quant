                  "type": "text",
                  "id": "oZ086",
                  "name": "t12",
                  "fill": "#0A0A0A",
                  "content": " ",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "RfPdA",
                  "name": "t13",
                  "fill": "#FAFAFA",
                  "content": "Found the issue. Multiple goroutines can trigger concurrent token refreshes.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "sd9b2",
                  "name": "t14",
                  "fill": "#FAFAFA",
                  "content": "Adding a sync.Mutex to serialize refresh operations.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "BmzxO",
                  "name": "u1",
                  "fill": "#0A0A0A",
                  "content": " ",
